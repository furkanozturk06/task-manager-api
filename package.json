{
  "name": "task-manager",
  "version": "1.0.0",
  "description": "Task Manager API",
  "scripts": {
    "dev": "ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "ts-node src/seed.ts",
    "test": "vitest run --reporter verbose",
    "test:smoke": "vitest run --reporter verbose tests/smoke",
    "test:unit": "vitest run --reporter verbose tests/unit",
    "client:dev": "cd client && npm run dev",
    "client:install": "cd client && npm install",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"client/src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\"",
    "lint:stage1": "node scripts/run-eslint-report.mjs --stage stage1",
    "lint:stage2": "node scripts/run-eslint-report.mjs --stage stage2",
    "sonar:up": "docker compose -f docker-compose.sonarqube.yml up -d",
    "sonar:down": "docker compose -f docker-compose.sonarqube.yml down",
    "sonar:scan": "sonar-scanner",
    "sonar:fetch:stage1": "node scripts/fetch-sonar-reports.mjs --stage stage1",
    "sonar:fetch:stage2": "node scripts/fetch-sonar-reports.mjs --stage stage2",
    "analyze:stage1": "npm run lint:stage1 && npm run sonar:scan && npm run sonar:fetch:stage1",
    "analyze:stage2": "npm run lint:stage2 && npm run sonar:scan && npm run sonar:fetch:stage2"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.8.0",
    "connect-sqlite3": "^0.9.15",
    "express": "^4.18.2",
    "express-session": "^1.18.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.8",
    "@types/connect-sqlite3": "^0.9.5",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/node": "^20.11.5",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "supertest": "^6.3.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2"
  }
}
